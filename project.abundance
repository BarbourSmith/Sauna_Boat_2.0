                    {
                      "atomType": "GitHubMolecule",
                      "x": 0.2605820105820106,
                      "y": 0.3816155988857939,
                      "uniqueID": "id-319467",
                      "name": "Above",
                      "ioValues": [
                        {
                          "name": "B",
                          "ioValue": "__GEOMETRY_INPUT__"
                        },
                        {
                          "name": "A",
                          "ioValue": "__GEOMETRY_INPUT__"
                        }
                      ],
                      "topLevel": false,
                      "allAtoms": [
                        {
                          "atomType": "Output",
                          "x": 0.98,
                          "y": 0.5,
                          "uniqueID": "id-319468",
                          "ioValues": [
